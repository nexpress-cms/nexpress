# Without this file the Docker build context balloons (node_modules,
# .next, .git, uploads). Keep it tight.

# Dependencies — re-installed inside the image
node_modules
.pnpm-store

# Build artifacts — re-built inside the image
.next
dist
.turbo

# Local-only state
.env
.env.local
.env.*.local
public/media
.cache
coverage
*.log

# Editor / VCS noise
.git
.gitignore
.github
.vscode
.idea
.DS_Store
*.tsbuildinfo

# Tests + docs (not needed in the production image)
docs
**/*.test.ts
**/__tests__

# Existing image / compose config — copying docker/ back into the
# image is pointless
docker
Dockerfile
.dockerignore
