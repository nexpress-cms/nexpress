# ────────────────────────────────────────────────────────────────────────
# Required
# ────────────────────────────────────────────────────────────────────────

# Postgres connection string. The local dev container ships on :5433 to
# avoid colliding with a system Postgres on :5432.
DATABASE_URL=postgres://nexpress:nexpress@localhost:5433/nexpress

# Dedicated DB for `pnpm test:integration` — keeps fixture churn out of dev data.
# Create once: docker compose -f docker/docker-compose.yml exec db \
#   psql -U nexpress -d postgres -c "CREATE DATABASE nexpress_test;"
TEST_DATABASE_URL=postgres://nexpress:nexpress@localhost:5433/nexpress_test

# Used by `docker compose -f docker/docker-compose.yml up -d db` to bind
# the container's 5432 to a host port. Match it with DATABASE_URL above.
NEXPRESS_DB_PORT=5433

# JWT signing secret — must contain 32..1024 random characters in every environment.
# Rotating this invalidates every existing session.
# This short placeholder intentionally fails config validation until replaced,
# so set it before running any build or dev command.
NP_SECRET=change-me-in-production

# Public site URL (used in og:url, password-reset links, OpenAPI server entry).
SITE_URL=http://localhost:3000

# ────────────────────────────────────────────────────────────────────────
# Storage adapter (default: local disk under ./public/media)
# ────────────────────────────────────────────────────────────────────────

# NP_STORAGE_ADAPTER=local                 # exact: local, s3, or custom
# NP_STORAGE_DIR=./public/media            # local-only
# NP_STORAGE_URL=/media                    # local-only public URL prefix
# NP_S3_BUCKET=
# NP_S3_REGION=us-east-1
# NP_S3_ENDPOINT=                          # leave unset for AWS S3; set for MinIO/R2
# custom requires createBootstrap({ storageAdapter }); setup/ops cannot install it

# ────────────────────────────────────────────────────────────────────────
# Background jobs (pg-boss)
# ────────────────────────────────────────────────────────────────────────

# Set to "1" to enable job enqueue + start the worker. Without it, writes
# that would normally enqueue follow-up jobs (revalidation, email) silently
# drop them — fine for dev, not OK for production.
# NP_ENABLE_JOBS=1

# ────────────────────────────────────────────────────────────────────────
# API rate limiting (default: process-local memory)
# ────────────────────────────────────────────────────────────────────────

# Exact modes are memory or custom. Multi-node deployments must use custom
# and inject a shared adapter from src/proxy.ts with npCreateProxy().
# NP_RATE_LIMIT_ADAPTER=memory
# NP_REDIS_URL=redis://localhost:6379       # example for the Redis adapter

# ────────────────────────────────────────────────────────────────────────
# Observability (default: console logger + noop error reporter)
# ────────────────────────────────────────────────────────────────────────

# Exact logger modes are console or custom; reporter modes are noop or custom.
# Custom implementations are passed once from src/lib/observability.ts so the
# web process, worker, and direct scripts all share the same adapter contract.
# NP_LOGGER_ADAPTER=console
# NP_ERROR_REPORTER_ADAPTER=noop

# ────────────────────────────────────────────────────────────────────────
# Scheduled publishing
# ────────────────────────────────────────────────────────────────────────

# Bearer token guarding /api/internal/publish-scheduled and /api/internal/reindex.
# Leave unset to disable those endpoints (they refuse every request).
# See docs/scheduled-publishing.md for cron wiring.
# NP_SCHEDULER_TOKEN=

# ────────────────────────────────────────────────────────────────────────
# Email (password reset + invites)
# ────────────────────────────────────────────────────────────────────────

# Defaults to the Mailpit container in docker/docker-compose.yml — boot
# with `docker compose -f docker/docker-compose.yml up -d` and emails
# land in the inbox at http://localhost:8025.
#
# IMPORTANT: Next.js reads `.env` from `apps/web/`, not the monorepo
# root. The block below covers monorepo-level tooling (drizzle-kit,
# scripts that load this file via dotenv); make sure the same block
# is present in `apps/web/.env` for `next dev` to pick it up.
# `pnpm run setup` writes both files automatically. Modes are exactly
# noop, smtp, or custom; SMTP user/pass must appear together and secure
# must be exactly true or false.
NP_EMAIL_ADAPTER=smtp
NP_SMTP_HOST=localhost
NP_SMTP_PORT=1025
NP_SMTP_USER=dev
NP_SMTP_PASS=dev
NP_SMTP_FROM="NexPress dev <noreply@nexpress.local>"
NP_SMTP_SECURE=false

# Production: replace the SMTP_* values for your provider. Resend
# example below — replace SMTP_PASS with your API key:
# NP_SMTP_HOST=smtp.resend.com
# NP_SMTP_PORT=587
# NP_SMTP_USER=resend
# NP_SMTP_PASS=re_xxx
# NP_SMTP_FROM="Your site <noreply@yourdomain.com>"
# NP_SMTP_SECURE=false

# ────────────────────────────────────────────────────────────────────────
# Auth tuning (optional)
# ────────────────────────────────────────────────────────────────────────

# NP_TOKEN_EXPIRATION=7200                 # integer seconds, 1..2678400 (31d)
# NP_REFRESH_TOKEN_EXPIRATION=604800       # integer seconds, access TTL..31536000 (365d)
# NP_MAX_LOGIN_ATTEMPTS=5                  # integer, 1..100
# NP_LOCKOUT_DURATION=900                  # integer seconds, 1..2592000 (30d)

# Single-use token TTLs (#288). Tighten if you need a shorter
# attack window during an incident.
# NP_INVITE_TTL_HOURS=168                  # integer hours, 1..8760 (default 7d)
# NP_RESET_TTL_MINUTES=60                  # integer minutes, 1..43200 (default 1h)
# NP_VERIFY_TTL_HOURS=24                   # integer hours, 1..8760 (default 24h)
# NP_OAUTH_STATE_TTL_SECONDS=600           # integer seconds, 1..3600 (default 10min)

# ────────────────────────────────────────────────────────────────────────
# Operational thresholds (#289) — runtime tuning without recompile
# ────────────────────────────────────────────────────────────────────────

# Postgres connection / query bounds. Raise statement timeout if
# heavy admin workloads (audit search, bulk export) trip the
# default; lower if you'd rather fail fast and retry at the LB.
# NP_DB_CONNECTION_TIMEOUT_MS=5000          # cap on pool.connect() wait
# NP_DB_STATEMENT_TIMEOUT_MS=10000          # server-side per-query bound

# pg-boss worker liveness signal. Stale threshold is what the
# admin dashboard uses to flip a worker from healthy → unhealthy.
# Default is 3× heartbeat so a single missed beat doesn't alarm.
# NP_WORKER_HEARTBEAT_SECONDS=30
# NP_WORKER_STALE_THRESHOLD_SECONDS=90

# Per-job log retention. Frequent ops question is "show me last
# week's failures" — pick a window that matches your compliance
# regime (GDPR / SOX / industry).
# NP_JOB_LOG_RETENTION_DAYS=14

# Trailing window for member upload quotas (`perDay` in the
# community settings). Override to widen ("weekly cap of N
# uploads") without touching code.
# NP_MEMBER_QUOTA_WINDOW_HOURS=24

# ────────────────────────────────────────────────────────────────────────
# Initial admin (used by `pnpm seed:admin`)
# ────────────────────────────────────────────────────────────────────────

# NP_ADMIN_EMAIL=admin@example.com
# NP_ADMIN_NAME="Site Admin"
# NP_ADMIN_PASSWORD=change-me-on-first-login

# ────────────────────────────────────────────────────────────────────────
# Dev build speed
# ────────────────────────────────────────────────────────────────────────

# Skips dts emit + sourcemaps in tsup --watch so the dev loop runs at
# transpile-only cost. `.d.ts` files refresh on the next `pnpm build`,
# which always emits full dts regardless of this flag. Set to 0 if you
# want the dev watch to keep types fresh (slower startup).
NP_DEV_FAST=1
