DATABASE_URL=postgres://nexpress:nexpress@localhost:5433/nexpress
NEXPRESS_DB_PORT=5433
NX_SECRET=change-me-in-production
SITE_URL=http://localhost:3000

# Scheduled publishing / reindex triggers — bearer token guarding
# /api/internal/publish-scheduled and /api/internal/reindex. Leave unset
# to keep these endpoints disabled (they refuse every request).
# NX_SCHEDULER_TOKEN=

# Email delivery for password-reset + invite flows.
# Unset / "noop" keeps the dev stub (logs the reset URL to stdout, no
# actual mail goes out). Use "smtp" to enable the nodemailer-based
# SMTP adapter — works with any SMTP-capable provider.
# NX_EMAIL_ADAPTER=smtp
# NX_SMTP_HOST=smtp.resend.com
# NX_SMTP_PORT=587
# NX_SMTP_USER=resend
# NX_SMTP_PASS=
# NX_SMTP_FROM="NexPress <noreply@example.com>"
# NX_SMTP_SECURE=false
