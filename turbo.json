{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "NP_SECRET",
    "NP_AUTH_SECRET",
    "AUTH_SECRET",
    "DATABASE_URL",
    "SITE_URL",
    "NP_STORAGE_ADAPTER",
    "NP_STORAGE_DIR",
    "NP_STORAGE_URL",
    "NP_S3_BUCKET",
    "NP_S3_REGION",
    "NP_S3_ENDPOINT",
    "NP_EMAIL_ADAPTER",
    "NP_SMTP_HOST",
    "NP_SMTP_PORT",
    "NP_SMTP_USER",
    "NP_SMTP_PASS",
    "NP_SMTP_FROM",
    "NP_SMTP_SECURE",
    "NP_ENABLE_JOBS",
    "NP_SCHEDULER_TOKEN",
    "NP_TOKEN_EXPIRATION",
    "NP_REFRESH_TOKEN_EXPIRATION",
    "NP_MAX_LOGIN_ATTEMPTS",
    "NP_LOCKOUT_DURATION",
    "NP_OAUTH_GITHUB_CLIENT_ID",
    "NP_OAUTH_GITHUB_CLIENT_SECRET",
    "NP_OAUTH_GOOGLE_CLIENT_ID",
    "NP_OAUTH_GOOGLE_CLIENT_SECRET",
    "TEST_DATABASE_URL",
    "NP_DEV_FAST"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "dist/**"]
    },
    "create-nexpress#build": {
      "dependsOn": ["^build"],
      "inputs": ["$TURBO_DEFAULT$", "$TURBO_ROOT$/packages/core/package.json"],
      "outputs": ["dist/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "@nexpress/web#typecheck": {
      "dependsOn": ["build"]
    },
    "lint": {
      "outputs": [],
      "inputs": [
        "src/**/*.{ts,tsx,js,jsx,mjs,cjs}",
        "tsconfig*.json",
        "package.json",
        "$TURBO_ROOT$/eslint.config.mjs",
        "$TURBO_ROOT$/tsconfig.base.json"
      ]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": []
    },
    "test:integration": {
      "dependsOn": ["^build"],
      "outputs": [],
      "cache": false
    },
    "clean": {
      "cache": false
    },
    "db:generate": {
      "cache": false
    },
    "db:migrate": {
      "cache": false
    },
    "generate:types": {
      "dependsOn": ["^build"],
      "outputs": ["src/nexpress-types.ts"]
    }
  }
}
