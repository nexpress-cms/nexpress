{
  "extends": "@nexpress/app/config/tsconfig-base",
  "compilerOptions": {
    "target": "ES2017",
    "outDir": null,
    "declaration": false,
    "declarationMap": false,
    "sourceMap": false,
    "composite": false,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src", "next-env.d.ts", ".next/types/**/*.ts", ".next/dev/types/**/*.ts"],
  "exclude": ["node_modules", "src/db/generated"]
}
