{
  "name": "@nexpress/web",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "dev": "next dev",
    "start": "next start",
    "lint": "tsc --noEmit",
    "clean": "rm -rf .next",
    "test": "vitest run",
    "test:watch": "vitest",
    "schema:gen": "tsx scripts/generate-schema.ts",
    "seed:admin": "tsx scripts/seed-admin.ts",
    "worker": "tsx scripts/worker.ts",
    "db:generate": "pnpm schema:gen && drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "pnpm schema:gen && drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@nexpress/admin": "workspace:*",
    "@nexpress/blocks": "workspace:*",
    "@nexpress/core": "workspace:*",
    "@nexpress/editor": "workspace:*",
    "@nexpress/next": "workspace:*",
    "@nexpress/plugin-reading-time": "workspace:*",
    "@nexpress/plugin-seo-audit": "workspace:*",
    "@nexpress/plugin-sdk": "workspace:*",
    "@nexpress/theme": "workspace:*",
    "drizzle-orm": "^0.45.2",
    "next": "^15.3.0",
    "nodemailer": "^7.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.2.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv": "^17.2.4",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.20.6",
    "postcss": "^8.5.10",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.8.0"
  }
}
