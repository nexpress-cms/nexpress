{
  "name": "nexpress",
  "private": true,
  "version": "0.0.0",
  "description": "Next.js-based open-source CMS",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "NP_DEV_FAST=0 node --env-file-if-exists=.env ./node_modules/turbo/bin/turbo run build",
    "dev": "node --env-file-if-exists=.env ./node_modules/turbo/bin/turbo run dev --filter=@nexpress/web --concurrency=10",
    "dev:full": "node --env-file-if-exists=.env ./node_modules/turbo/bin/turbo run dev --concurrency=50",
    "lint": "node --env-file-if-exists=.env ./node_modules/turbo/bin/turbo run lint --concurrency=2",
    "lint:fix": "node --env-file-if-exists=.env ./node_modules/turbo/bin/turbo run lint --concurrency=2 -- --fix",
    "typecheck": "NP_DEV_FAST=0 node --env-file-if-exists=.env ./node_modules/turbo/bin/turbo run typecheck",
    "test": "pnpm test:repo && NP_DEV_FAST=0 node --env-file-if-exists=.env ./node_modules/turbo/bin/turbo run test",
    "test:repo": "tsx --test scripts/*.test.mts scripts/*.test.mjs",
    "test:integration": "NP_DEV_FAST=0 node --env-file-if-exists=.env ./node_modules/turbo/bin/turbo run test:integration --concurrency=1",
    "verify": "pnpm test:repo && NP_DEV_FAST=0 node --env-file-if-exists=.env ./node_modules/turbo/bin/turbo run build typecheck test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "node --env-file-if-exists=.env ./node_modules/turbo/bin/turbo run db:generate",
    "db:migrate": "node --env-file-if-exists=.env ./node_modules/turbo/bin/turbo run db:migrate",
    "setup": "pnpm --filter @nexpress/web run setup",
    "doctor": "pnpm --filter @nexpress/web run doctor",
    "ops:release": "pnpm --filter @nexpress/web run release",
    "ops:runbook": "pnpm --filter @nexpress/web run runbook",
    "seed:admin": "pnpm --filter @nexpress/web seed:admin",
    "seed:content": "pnpm --filter @nexpress/web seed:content",
    "ux-audit": "tsx scripts/ux-audit.mts",
    "clean": "node --env-file-if-exists=.env ./node_modules/turbo/bin/turbo run clean && rm -rf node_modules",
    "changeset": "changeset",
    "version": "pnpm test:repo && changeset version",
    "release": "pnpm test:repo && pnpm build && changeset publish --no-git-tag && tsx scripts/tag-release.mts"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@types/node": "^26.0.1",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.7.0",
    "prettier": "^3.9.5",
    "tsx": "^4.22.4",
    "turbo": "^2.10.4",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.63.0",
    "vitest": "^4.1.10"
  },
  "pnpm": {
    "overrides": {
      "@babel/core": "7.29.7",
      "esbuild": "0.28.1",
      "js-yaml": "4.2.0",
      "postcss": "8.5.16",
      "shell-quote": "1.8.4",
      "vite": "7.3.5"
    },
    "onlyBuiltDependencies": [
      "@node-rs/argon2",
      "esbuild",
      "sharp"
    ],
    "peerDependencyRules": {
      "ignoreMissing": [
        "@playwright/test"
      ]
    },
    "patchedDependencies": {
      "read-yaml-file@1.1.0": "patches/read-yaml-file@1.1.0.patch"
    }
  }
}
