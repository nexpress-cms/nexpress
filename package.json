{
  "name": "nexpress",
  "private": true,
  "version": "0.0.0",
  "description": "Next.js-based open-source CMS",
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "node scripts/run-with-env.mjs turbo run build",
    "dev": "node scripts/run-with-env.mjs turbo run dev --concurrency=20",
    "lint": "NODE_OPTIONS='--max-old-space-size=8192' eslint .",
    "lint:fix": "NODE_OPTIONS='--max-old-space-size=8192' eslint . --fix",
    "typecheck": "node scripts/run-with-env.mjs turbo run lint",
    "test": "node scripts/run-with-env.mjs turbo run test",
    "test:integration": "node scripts/run-with-env.mjs turbo run test:integration --concurrency=1",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "db:generate": "node scripts/run-with-env.mjs turbo run db:generate",
    "db:migrate": "node scripts/run-with-env.mjs turbo run db:migrate",
    "clean": "node scripts/run-with-env.mjs turbo run clean && rm -rf node_modules"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^22.0.0",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import-x": "^4.16.2",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.5.0",
    "prettier": "^3.5.0",
    "turbo": "^2.5.0",
    "typescript": "^5.8.0",
    "typescript-eslint": "^8.58.2",
    "vitest": "^3.2.4"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@node-rs/argon2",
      "esbuild",
      "sharp"
    ]
  }
}
