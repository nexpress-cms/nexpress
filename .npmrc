shamefully-hoist=false
strict-peer-dependencies=true
# pnpm 10's default reporter collapses lifecycle-script stdout into
# a single "Done in Xs" line. That swallows our postinstall onboarding
# pointer when stdout is short. `append-only` streams lifecycle output
# as it arrives so first-time operators actually read the
# "Run pnpm run setup" hint.
reporter=append-only
