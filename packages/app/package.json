{
  "name": "@nexpress/app",
  "version": "0.3.10",
  "description": "Shared Next.js page implementations for NexPress reference + scaffolded apps. Consumers import via thin re-export so both apps/web and `npx create-nexpress` projects render byte-identical UIs.",
  "license": "MIT",
  "author": "Nexpress",
  "homepage": "https://github.com/nexpress-cms/nexpress#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/nexpress-cms/nexpress.git",
    "directory": "packages/app"
  },
  "bugs": {
    "url": "https://github.com/nexpress-cms/nexpress/issues"
  },
  "keywords": [
    "nexpress",
    "nextjs",
    "app-router",
    "pages"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./admin/*": {
      "types": "./src/admin/*.tsx",
      "import": "./src/admin/*.tsx",
      "default": "./src/admin/*.tsx"
    },
    "./site/*": {
      "types": "./src/site/*.tsx",
      "import": "./src/site/*.tsx",
      "default": "./src/site/*.tsx"
    },
    "./member/*": {
      "types": "./src/member/*.tsx",
      "import": "./src/member/*.tsx",
      "default": "./src/member/*.tsx"
    },
    "./api/*": {
      "types": "./src/api/*.ts",
      "import": "./src/api/*.ts",
      "default": "./src/api/*.ts"
    },
    "./root/layout": {
      "types": "./src/root/layout.tsx",
      "import": "./src/root/layout.tsx",
      "default": "./src/root/layout.tsx"
    },
    "./root/*": {
      "types": "./src/root/*.ts",
      "import": "./src/root/*.ts",
      "default": "./src/root/*.ts"
    },
    "./scripts/*": {
      "types": "./dist/scripts/*.d.ts",
      "import": "./dist/scripts/*.js",
      "default": "./dist/scripts/*.js"
    },
    "./lib/*": {
      "types": "./dist/lib/*.d.ts",
      "import": "./dist/lib/*.js",
      "default": "./dist/lib/*.js"
    },
    "./collections/*": {
      "types": "./src/collections/*.ts",
      "import": "./src/collections/*.ts",
      "default": "./src/collections/*.ts"
    },
    "./config/next-config": {
      "types": "./src/config/next-config.ts",
      "import": "./src/config/next-config.ts",
      "default": "./src/config/next-config.ts"
    },
    "./config/drizzle-config": {
      "types": "./src/config/drizzle-config.ts",
      "import": "./src/config/drizzle-config.ts",
      "default": "./src/config/drizzle-config.ts"
    },
    "./config/postcss-config": {
      "types": "./src/config/postcss-config.ts",
      "import": "./src/config/postcss-config.ts",
      "default": "./src/config/postcss-config.ts"
    },
    "./config/tsconfig-base": "./src/config/tsconfig.base.json",
    "./config/next-env.d.ts": "./src/config/next-env.d.ts",
    "./config-defaults": {
      "types": "./src/config-defaults/index.ts",
      "import": "./src/config-defaults/index.ts",
      "default": "./src/config-defaults/index.ts"
    },
    "./proxy": {
      "types": "./src/proxy/index.ts",
      "import": "./src/proxy/index.ts",
      "default": "./src/proxy/index.ts"
    },
    "./i18n-config": {
      "types": "./src/i18n-config.ts",
      "import": "./src/i18n-config.ts",
      "default": "./src/i18n-config.ts"
    },
    "./styles/globals.css": "./src/styles/globals.css"
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@nexpress/admin": "workspace:*",
    "@nexpress/auth-pages": "workspace:*",
    "@nexpress/blocks": "workspace:*",
    "@nexpress/core": "workspace:*",
    "@nexpress/editor": "workspace:*",
    "@nexpress/next": "workspace:*",
    "@nexpress/plugin-block-callout": "workspace:*",
    "@nexpress/plugin-block-embed": "workspace:*",
    "@nexpress/plugin-block-latest-posts": "workspace:*",
    "@nexpress/plugin-block-newsletter": "workspace:*",
    "@nexpress/plugin-block-pricing": "workspace:*",
    "@nexpress/plugin-block-stats": "workspace:*",
    "@nexpress/plugin-forum": "workspace:*",
    "@nexpress/plugin-oauth-github": "workspace:*",
    "@nexpress/plugin-oauth-google": "workspace:*",
    "@nexpress/plugin-reading-time": "workspace:*",
    "@nexpress/plugin-sdk": "workspace:*",
    "@nexpress/plugin-seo-audit": "workspace:*",
    "@nexpress/theme": "workspace:*",
    "@nexpress/theme-default": "workspace:*",
    "@nexpress/theme-docs": "workspace:*",
    "@nexpress/theme-magazine": "workspace:*",
    "@nexpress/theme-portfolio": "workspace:*",
    "dotenv": "^17.2.4",
    "drizzle-orm": "^0.45.2"
  },
  "peerDependencies": {
    "drizzle-kit": "^0.31.0",
    "next": "^15.0.0 || ^16.0.0",
    "pg": "^8.13.0",
    "pg-boss": "^10.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "drizzle-kit": {
      "optional": true
    },
    "pg-boss": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/pg": "^8.15.5",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "drizzle-kit": "^0.31.10",
    "next": "^16.0.0",
    "pg": "^8.21.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0"
  }
}
