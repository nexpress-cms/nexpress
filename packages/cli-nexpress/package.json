{
  "name": "@nexpress/cli",
  "version": "0.5.0",
  "description": "Project-side CLI for NexPress — manage plugins, themes, ops, and release handoffs.",
  "license": "MIT",
  "author": "Nexpress",
  "homepage": "https://github.com/nexpress-cms/nexpress#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/nexpress-cms/nexpress.git",
    "directory": "packages/cli-nexpress"
  },
  "bugs": {
    "url": "https://github.com/nexpress-cms/nexpress/issues"
  },
  "keywords": [
    "nexpress",
    "cli",
    "plugins",
    "themes"
  ],
  "type": "module",
  "bin": {
    "nexpress": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --no-clean",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --cache --cache-location node_modules/.cache/eslint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@nexpress/core": "workspace:*",
    "picocolors": "^1.1.1",
    "ts-morph": "^28.0.0"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^4.1.10"
  }
}
