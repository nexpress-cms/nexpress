{
  "name": "@nexpress/theme",
  "version": "0.3.23",
  "description": "Theme engine for NexPress — CSS custom property generation from design tokens.",
  "license": "MIT",
  "author": "Nexpress",
  "homepage": "https://github.com/nexpress-cms/nexpress#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/nexpress-cms/nexpress.git",
    "directory": "packages/theme"
  },
  "bugs": {
    "url": "https://github.com/nexpress-cms/nexpress/issues"
  },
  "keywords": [
    "nexpress",
    "theme",
    "css"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "next": "^16.2.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "peerDependenciesMeta": {
    "next": {
      "optional": true
    }
  },
  "dependencies": {
    "@nexpress/blocks": "workspace:*",
    "@nexpress/core": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.0",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --no-clean",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --cache --cache-location node_modules/.cache/eslint"
  }
}
