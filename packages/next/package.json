{
  "name": "@nexpress/next",
  "version": "0.1.0",
  "description": "Next.js integration helpers for NexPress — bootstrap, auth, collections.",
  "license": "MIT",
  "author": "Nexpress",
  "homepage": "https://github.com/hahabsw/nexpress#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/hahabsw/nexpress.git",
    "directory": "packages/next"
  },
  "bugs": {
    "url": "https://github.com/hahabsw/nexpress/issues"
  },
  "keywords": [
    "nexpress",
    "nextjs",
    "bootstrap"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "next": ">=15",
    "react": "^19.0.0"
  },
  "dependencies": {
    "@nexpress/blocks": "workspace:*",
    "@nexpress/core": "workspace:*",
    "@nexpress/theme": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "next": "^16.2.4",
    "react": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --no-clean",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --cache --cache-location node_modules/.cache/eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  }
}
