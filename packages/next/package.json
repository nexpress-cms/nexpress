{
  "name": "@nexpress/next",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": ["dist"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --no-clean",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "peerDependencies": {
    "next": ">=15"
  },
  "dependencies": {
    "@nexpress/core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "next": "^16.2.4",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0"
  }
}
