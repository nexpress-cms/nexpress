{
  "name": "@nexpress/auth-pages",
  "version": "0.1.3",
  "description": "Server route factories + headless React hooks for member auth pages — login, register, password reset, verify, OAuth.",
  "license": "MIT",
  "author": "Nexpress",
  "homepage": "https://github.com/nexpress-cms/nexpress#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/nexpress-cms/nexpress.git",
    "directory": "packages/auth-pages"
  },
  "bugs": {
    "url": "https://github.com/nexpress-cms/nexpress/issues"
  },
  "keywords": [
    "nexpress",
    "auth",
    "members",
    "login",
    "register",
    "oauth",
    "react"
  ],
  "type": "module",
  "main": "./dist/server.js",
  "types": "./dist/server.d.ts",
  "exports": {
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js",
      "default": "./dist/server.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js",
      "default": "./dist/client.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "next": ">=15",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@nexpress/core": "workspace:*",
    "@nexpress/next": "workspace:*",
    "drizzle-orm": "^0.45.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "next": "^16.2.6",
    "react": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0"
  },
  "scripts": {
    "build": "rm -rf dist && tsup",
    "dev": "tsup --watch --no-clean",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --cache --cache-location node_modules/.cache/eslint",
    "test": "vitest run",
    "test:watch": "vitest"
  }
}
