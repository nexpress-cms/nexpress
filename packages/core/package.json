{
  "name": "@nexpress/core",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./db-schema": {
      "types": "./dist/db-schema.d.ts",
      "import": "./dist/db-schema.js",
      "default": "./dist/db-schema.js"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --no-clean",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:integration": "vitest run -c vitest.integration.config.ts"
  },
  "devDependencies": {
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0"
  },
  "peerDependencies": {
    "nodemailer": "^7.0.0"
  },
  "peerDependenciesMeta": {
    "nodemailer": {
      "optional": true
    }
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.840.0",
    "@node-rs/argon2": "^2.0.2",
    "arctic": "^3.7.0",
    "drizzle-orm": "^0.45.2",
    "jose": "^6.2.2",
    "pg": "^8.20.0",
    "pg-boss": "^12.15.0",
    "sharp": "^0.34.2",
    "zod": "^4.3.6"
  }
}
