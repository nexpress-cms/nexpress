{
  "name": "@nexpress/blocks",
  "version": "0.3.11",
  "description": "Block-based page builder for NexPress.",
  "license": "MIT",
  "author": "Nexpress",
  "homepage": "https://github.com/nexpress-cms/nexpress#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/nexpress-cms/nexpress.git",
    "directory": "packages/blocks"
  },
  "bugs": {
    "url": "https://github.com/nexpress-cms/nexpress/issues"
  },
  "keywords": [
    "nexpress",
    "blocks",
    "page-builder"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@nexpress/core": "workspace:*",
    "@nexpress/editor": "workspace:*"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --no-clean",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --cache --cache-location node_modules/.cache/eslint",
    "test": "vitest run",
    "test:watch": "vitest"
  }
}
