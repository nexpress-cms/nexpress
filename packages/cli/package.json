{
  "name": "create-nexpress",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "create-nexpress": "./dist/index.js"
  },
  "files": ["dist", "templates"],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --no-clean",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.templates.json",
    "test": "vitest run"
  },
  "dependencies": {
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@nexpress/blocks": "workspace:*",
    "@nexpress/core": "workspace:*",
    "@nexpress/next": "workspace:*",
    "@nexpress/theme": "workspace:*",
    "@types/prompts": "^2.4.9",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv": "^17.2.4",
    "drizzle-orm": "^0.45.2",
    "next": "^16.2.4",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0"
  }
}
