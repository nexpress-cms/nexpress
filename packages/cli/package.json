{
  "name": "create-nexpress",
  "version": "0.1.7",
  "description": "Scaffolder CLI for new NexPress projects (npx create-nexpress).",
  "license": "MIT",
  "author": "Nexpress",
  "homepage": "https://github.com/nexpress-cms/nexpress#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/nexpress-cms/nexpress.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/nexpress-cms/nexpress/issues"
  },
  "keywords": [
    "nexpress",
    "cli",
    "scaffolder",
    "create-nexpress"
  ],
  "type": "module",
  "bin": {
    "create-nexpress": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@nexpress/admin": "workspace:*",
    "@nexpress/auth-pages": "workspace:*",
    "@nexpress/blocks": "workspace:*",
    "@nexpress/core": "workspace:*",
    "@nexpress/next": "workspace:*",
    "@nexpress/theme": "workspace:*",
    "@types/prompts": "^2.4.9",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "dotenv": "^17.2.4",
    "drizzle-orm": "^0.45.2",
    "next": "^16.2.6",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --no-clean",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.templates.json",
    "lint": "eslint . --cache --cache-location node_modules/.cache/eslint",
    "test": "vitest run"
  }
}
