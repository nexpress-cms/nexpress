{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    // The base config sets `declaration: true` for the regular
    // package builds. Templates aren't published as a typed
    // package — they're file-copied into scaffolded projects,
    // which run their own `tsc` against their own deps. Turn
    // declaration generation off here so tsc doesn't insist
    // every inferred export be portably namable from this
    // package's `node_modules` graph.
    "declaration": false,
    "declarationMap": false,
    "rootDir": "templates",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "jsx": "preserve",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./templates/_typecheck/*", "./templates/*"]
    }
  },
  // After the single-source-of-truth refactor, scripts and
  // collections are no longer authored as on-disk template files —
  // every scaffolded `scripts/*.ts` and `src/collections/*.ts` is a
  // 1-3 line re-export from `@nexpress/app`. The substantive code
  // lives in `packages/app/src/{scripts,collections}/` and is
  // typechecked by `pnpm --filter @nexpress/app typecheck`.
  //
  // The snapshot subtree (`templates/snapshot/`) also stays out of
  // this typecheck: it's an opaque, byte-identical mirror of
  // apps/web's `src/{app,lib,i18n.config.ts,proxy.ts}` and apps/web's
  // own `tsc --noEmit` validates that surface.
  //
  // The include + files arrays below are kept as anchors so
  // `tsc --noEmit -p tsconfig.templates.json` exits 0 (rather than
  // erroring on an empty graph) — the `_typecheck/` stubs are still
  // useful when re-introducing on-disk script templates in future.
  "include": [
    "templates/_typecheck/**/*.ts"
  ]
}
