{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    // The base config sets `declaration: true` for the regular
    // package builds. Templates aren't published as a typed
    // package — they're file-copied into scaffolded projects,
    // which run their own `tsc` against their own deps. Turn
    // declaration generation off here so tsc doesn't insist
    // every inferred export be portably namable from this
    // package's `node_modules` graph.
    "declaration": false,
    "declarationMap": false,
    "rootDir": "templates",
    "moduleResolution": "Bundler",
    "module": "ESNext",
    "jsx": "preserve",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["./templates/_typecheck/*", "./templates/*"]
    }
  },
  // After #702-#704, the bulk of routable code (admin pages, site
  // pages, api routes, lib/) moved into @nexpress/app and is
  // mirrored into a scaffold via the `templates/snapshot/` subtree
  // as opaque, byte-identical copies of apps/web. apps/web's own
  // typecheck pass validates that surface, so we don't redo the
  // work here — typing those files against the CLI's tsconfig
  // would also require the full reference-app dep graph (Drizzle,
  // every @nexpress/* package, generated documents) reachable
  // from packages/cli/node_modules. Keep this typecheck focused
  // on what the scaffold actually authors: collections (which
  // are operator-editable examples) and bootstrap scripts.
  "include": [
    "templates/scripts/**/*.ts",
    "templates/collections/**/*.ts"
  ],
  "files": [
    "templates/_typecheck/db/generated/collections.ts",
    "templates/_typecheck/nexpress.config.ts"
  ]
}
