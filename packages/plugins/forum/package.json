{
  "name": "@nexpress/plugin-forum",
  "version": "0.1.0",
  "description": "Forum plugin for NexPress — threaded discussions on top of the community surface.",
  "license": "MIT",
  "author": "Nexpress",
  "homepage": "https://github.com/hahabsw/nexpress#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/hahabsw/nexpress.git",
    "directory": "packages/plugins/forum"
  },
  "bugs": {
    "url": "https://github.com/hahabsw/nexpress/issues"
  },
  "keywords": [
    "nexpress",
    "plugin",
    "forum",
    "discussions"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@nexpress/core": "workspace:*",
    "@nexpress/plugin-sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.5.0",
    "typescript": "^5.8.0"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --no-clean",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --cache --cache-location node_modules/.cache/eslint",
    "prepublishOnly": "pnpm build"
  }
}
