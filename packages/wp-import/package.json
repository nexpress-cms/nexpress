{
  "name": "@nexpress/wp-import",
  "version": "0.1.0",
  "description": "WordPress (WXR) importer for NexPress — HTML to Lexical conversion, media pipeline, taxonomies, comments.",
  "license": "MIT",
  "author": "Seungwon Bae <hahabsw@gmail.com>",
  "homepage": "https://github.com/hahabsw/nexpress#readme",
  "repository": {
    "type": "git",
    "url": "https://github.com/hahabsw/nexpress.git",
    "directory": "packages/wp-import"
  },
  "bugs": {
    "url": "https://github.com/hahabsw/nexpress/issues"
  },
  "keywords": [
    "nexpress",
    "wordpress",
    "wxr",
    "import",
    "migration"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@nexpress/core": "workspace:*",
    "fast-xml-parser": "^5.5.8",
    "node-html-parser": "^7.0.1"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.8.0",
    "vitest": "^3.2.4"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch --no-clean",
    "clean": "rm -rf dist",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "pnpm build"
  }
}
